# Public app mode. Safe to expose in the browser.
NEXT_PUBLIC_APP_ENV=local
NEXT_PUBLIC_SENTRY_DSN=

# Server-only values. Copy this file to apps/web/.env.local for local dev.
# Root database scripts also read apps/web/.env.local when DATABASE_URL is not exported.
AUTH_PROVIDER=local
AUTH_SESSION_SECRET=
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dnd_companion
AI_GROUNDING_MODE=disabled
OPENAI_API_KEY=
OPENAI_MODEL=
OBSERVABILITY_PROVIDER=console
SENTRY_DSN=
LOG_LEVEL=info
STORAGE_PROVIDER=none
BLOB_READ_WRITE_TOKEN=

