# Public app mode and provider identifiers. Safe to expose in the browser.
NEXT_PUBLIC_APP_ENV=local
APP_BASE_URL=http://localhost:3000
# Clerk managed authentication. Required when AUTH_PROVIDER=clerk.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=https://egrmvhfroiumcodkotjv.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SENTRY_DSN=

# Server-only values. Copy this file to apps/web/.env.local for local dev.
# Root database scripts also read apps/web/.env.local when DATABASE_URL is not exported.
# Keep local for deterministic contributor accounts, or use clerk to test real auth.
AUTH_PROVIDER=local
# Only used by the local auth provider. Managed Clerk sessions do not use it.
AUTH_SESSION_SECRET=
# Clerk secret key. Required when AUTH_PROVIDER=clerk.
CLERK_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Hosted Supabase Postgres for DND-33. Replace the password locally or in deployment secrets.
# URL-encode special characters in the password and keep sslmode=require.
DATABASE_URL=postgresql://postgres:REPLACE_WITH_SUPABASE_DATABASE_PASSWORD@db.egrmvhfroiumcodkotjv.supabase.co:5432/postgres?sslmode=require
DATABASE_POOL_MAX=5
DATABASE_CONNECTION_TIMEOUT_MS=10000
DATABASE_IDLE_TIMEOUT_MS=30000
AI_GROUNDING_MODE=disabled
OPENAI_API_KEY=
OPENAI_MODEL=
OBSERVABILITY_PROVIDER=console
SENTRY_DSN=
LOG_LEVEL=info
STORAGE_PROVIDER=none
BLOB_READ_WRITE_TOKEN=

